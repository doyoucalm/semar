{
  "name": "@semar/cli",
  "version": "0.0.1",
  "private": true,
  "description": "Semar CLI — interactive wrapper for all engines + JSONL diary log",
  "type": "module",
  "bin": {
    "semar": "./src/index.ts"
  },
  "scripts": {
