    "@semar/pawukon": "workspace:*",
    "@semar/tarot": "workspace:*",
    "@semar/zwds": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.22.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
